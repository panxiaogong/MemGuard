# AMP-Engine — memguard 运行时配置
# 复制此文件为 .env 并填入真实值

# ── LLM & Embedding API ──────────────────────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai-proxy.org/v1
ANTHROPIC_API_KEY=

# 选择 embedding 提供商: openai | anthropic
EMBEDDING_PROVIDER=openai
# OpenAI: text-embedding-3-small | text-embedding-3-large | text-embedding-ada-002
# Anthropic: voyage-3 (via voyage-ai, openai-compatible endpoint)
EMBEDDING_MODEL=text-embedding-3-small

# 影子执行使用的模型
SHADOW_EXEC_MODEL=gpt-4o-mini
# 若使用 Anthropic: claude-haiku-4-5-20251001

# ── Ed25519 签名密钥 ──────────────────────────────────────
# base64-encoded raw 32-byte private key
# 首次启动若留空，系统将自动生成并打印，请手动填入。
MEMGUARD_ED25519_PRIVATE_KEY=tt7QSkFkwjRTFpAZ/R1/3ncRoC6qgNfXZrBj1sZ5/B8=

# ── 向量数据库 ────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=agent_memory

# ── 网关服务 ──────────────────────────────────────────────
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

# ── 定期巡检器 ───────────────────────────────────────────
SCAN_INTERVAL_MINUTES=5
SCAN_SAMPLE_SIZE=20

# ── 审计日志 ──────────────────────────────────────────────
AUDIT_LOG_FILE=logs/memguard_audit.jsonl
